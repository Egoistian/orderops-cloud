# Local PostgreSQL database used by the API.
DATABASE_URL=postgresql://localhost/orderops_cloud

# API port. Vite proxies /api requests to this port.
PORT=8787
HOST=127.0.0.1

# Optional: defaults to 10 on a normal server and 2 on Vercel.
DATABASE_POOL_MAX=10

# Password for the shared access accounts. Keep it separate from personal credentials.
ACCESS_ACCOUNT_PASSWORD=orderops-access-2026

# Keep false for the normal local app. Set true when visitors use shared access accounts.
# Shared access mode resets the authenticated tenant on login, replaces audit notes,
# and applies per-process login/reset and status-mutation limits.
SHARED_ACCESS_MODE=false

NODE_ENV=development
