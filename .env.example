# Local PostgreSQL database used by the API.
DATABASE_URL=postgresql://localhost/orderops_cloud_portfolio

# API port. Vite proxies /api requests to this port.
PORT=8787
HOST=127.0.0.1

# Optional: defaults to 10 on a normal server and 2 on Vercel.
DATABASE_POOL_MAX=10

# Public portfolio-demo password only. Never reuse a real password here.
SEED_DEMO_PASSWORD=orderops-demo-2026

# Keep false for the normal local app. Set true only for a shared, synthetic public demo.
# Public mode resets the authenticated demo tenant on login, replaces audit notes,
# and applies per-process login/reset and status-mutation limits.
PUBLIC_DEMO_MODE=false

NODE_ENV=development
