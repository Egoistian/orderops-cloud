{
  "name": "orderops-cloud",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "node --env-file-if-exists=.env --watch server/index.mjs",
    "start": "node --env-file-if-exists=.env server/index.mjs",
    "db:setup": "node --env-file-if-exists=.env scripts/database.mjs setup",
    "db:migrate": "node --env-file-if-exists=.env scripts/database.mjs migrate",
    "db:seed": "node --env-file-if-exists=.env scripts/database.mjs seed",
    "db:reset": "node --env-file-if-exists=.env scripts/database.mjs reset",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "desktop": "npm run build && electron .",
    "desktop:smoke": "npm run build && node scripts/electron-smoke.mjs",
    "pack:win": "npm run build && node scripts/package-windows.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test src/orderEngine.test.mjs server/workflow.test.mjs",
    "test:integration": "node --env-file-if-exists=.env --test --test-concurrency=1 server/api.integration.test.mjs",
    "test:e2e": "node --env-file-if-exists=.env --test --test-concurrency=1 tests/e2e.test.mjs",
    "verify": "npm test && npm run test:integration && npm run typecheck && npm run test:e2e && npm audit --omit=dev"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@electron/packager": "^18.4.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.7.1",
    "playwright": "^1.61.1"
  }
}
